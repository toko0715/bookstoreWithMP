APP_NAME="Librería Online"
APP_ENV=production
APP_KEY=base64:REEMPLAZA_ESTA_CLAVE
APP_DEBUG=false
APP_URL=https://tu-app.onrender.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Base de datos de Render
DB_CONNECTION=pgsql
DB_HOST=REEMPLAZA_HOST_POSTGRES
DB_PORT=5432
DB_DATABASE=REEMPLAZA_DB
DB_USERNAME=REEMPLAZA_USER
DB_PASSWORD=REEMPLAZA_PASSWORD

# Para arrancar rápido en Render
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hola@tu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

STORE_CURRENCY=PEN
STORE_CURRENCY_SYMBOL="S/"
STORE_LOCALE=es_PE

# Cloudinary opcional
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=libreria/covers

# Mercado Pago Sandbox
# Usa las credenciales TEST del panel de desarrolladores
MP_ACCESS_TOKEN=TEST-REEMPLAZA_ACCESS_TOKEN
MP_PUBLIC_KEY=TEST-REEMPLAZA_PUBLIC_KEY
MP_CURRENCY=PEN
